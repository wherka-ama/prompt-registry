{
  "name": "@prompt-registry/collection-scripts",
  "version": "1.0.4",
  "description": "Prompt Registry library for managing Copilot prompt collections - CLI tools, search engine, and installation system",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./domain": {
      "types": "./dist/domain/index.d.ts",
      "default": "./dist/domain/index.js"
    },
    "./ports": {
      "types": "./dist/ports/index.d.ts",
      "default": "./dist/ports/index.js"
    },
    "./app": {
      "types": "./dist/app/index.d.ts",
      "default": "./dist/app/index.js"
    }
  },
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "prompt-registry": "./bin/prompt-registry.js",
    "validate-collections": "./bin/validate-collections.js",
    "validate-skills": "./bin/validate-skills.js",
    "build-collection-bundle": "./bin/build-collection-bundle.js",
    "compute-collection-version": "./bin/compute-collection-version.js",
    "detect-affected-collections": "./bin/detect-affected-collections.js",
    "generate-manifest": "./bin/generate-manifest.js",
    "publish-collections": "./bin/publish-collections.js",
    "list-collections": "./bin/list-collections.js",
    "create-skill": "./bin/create-skill.js",
    "hub-release-analyzer": "./bin/hub-release-analyzer.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "RUN_BENCH=1 vitest run 'test/github-bench.test.ts'",
    "test:with-bench": "npm test && npm run bench",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "lint:report": "eslint src test --format json --output-file eslint-report.json || true",
    "prepublishOnly": "npm run build",
    "build:sea": "node esbuild.config.mjs && ./scripts/generate-sea.sh ./dist/prompt-registry",
    "build:sea:linux-amd64": "npm run build:sea && mv ./dist/prompt-registry ./dist/prompt-registry-linux-amd64",
    "build:sea:linux-arm64": "npm run build:sea && mv ./dist/prompt-registry ./dist/prompt-registry-linux-arm64",
    "build:sea:darwin-amd64": "npm run build:sea && mv ./dist/prompt-registry ./dist/prompt-registry-darwin-amd64",
    "build:sea:darwin-arm64": "npm run build:sea && mv ./dist/prompt-registry ./dist/prompt-registry-darwin-arm64",
    "build:sea:windows-amd64": "node esbuild.config.mjs && ./scripts/generate-sea.sh ./dist/prompt-registry-windows-amd64.exe",
    "build:sea:windows-arm64": "node esbuild.config.mjs && ./scripts/generate-sea.sh ./dist/prompt-registry-windows-arm64.exe",
    "pack": "npm pack",
    "pack:inspect": "npm run pack && tar -tzf *.tgz | head -50"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AmadeusITGroup/prompt-registry.git",
    "directory": "lib"
  },
  "keywords": [
    "copilot",
    "prompts",
    "collections",
    "validation",
    "bundling"
  ],
  "author": "Prompt Registry Contributors",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AmadeusITGroup/prompt-registry/issues"
  },
  "homepage": "https://github.com/AmadeusITGroup/prompt-registry/tree/main/lib#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.json",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "clipanion": "^4.0.0-rc.4",
    "inquirer": "^9.3.8",
    "js-yaml": "^4.0.0",
    "semver": "^7.5.4",
    "typanion": "^3.14.0",
    "yauzl": "^3.1.3"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/inquirer": "^9.0.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/yauzl": "^2.10.3",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "postject": "^1.0.0-alpha.6",
    "sonar-scanner": "^3.1.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "js-yaml": "^4.0.0"
  }
}
