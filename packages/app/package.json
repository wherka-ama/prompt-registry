{
  "name": "@prompt-registry/app",
  "version": "1.0.0",
  "description": "Application layer for Prompt Registry - orchestration, install commands, registry management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AmadeusITGroup/prompt-registry.git",
