{
  "name": "@prompt-registry/cli",
  "version": "1.0.0",
  "description": "CLI for Prompt Registry - install, manage, and validate Copilot prompt collections",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "prompt-registry": "./bin/prompt-registry.js"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AmadeusITGroup/prompt-registry.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "prompt-registry",
    "cli",
    "copilot",
    "prompts",
    "collections"
  ],
  "author": "Amadeus IT Group",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@prompt-registry/core": "workspace:*",
    "@prompt-registry/infra": "workspace:*",
    "@prompt-registry/app": "workspace:*",
    "commander": "^12.0.0",
    "inquirer": "^9.2.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "@types/inquirer": "^9.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
