{
  "name": "@prompt-registry/cli",
  "version": "1.0.0",
  "description": "CLI for Prompt Registry - install, manage, and validate Copilot prompt collections",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "prompt-registry": "./bin/prompt-registry.js"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AmadeusITGroup/prompt-registry.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "prompt-registry",
    "cli",
    "copilot",
    "prompts",
    "collections"
  ],
  "author": "Amadeus IT Group",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "prepublishOnly": "npm run build",
    "build:sea": "node scripts/build-sea.js",
    "build:sea:local": "node scripts/build-sea.js --local"
  },
  "dependencies": {
    "@prompt-registry/app": "workspace:*",
    "@prompt-registry/core": "workspace:*",
    "@prompt-registry/infra": "workspace:*",
    "archiver": "^7.0.1",
    "clipanion": "^4.0.0-rc.4",
    "inquirer": "^9.3.8",
    "js-yaml": "^4.0.0",
    "semver": "^7.5.4",
    "typanion": "^3.14.0",
    "yauzl": "^3.1.3"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/inquirer": "^9.0.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/semver": "^7.5.0",
    "@types/yauzl": "^2.10.3",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.20.0",
    "postject": "^1.0.0-alpha.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
